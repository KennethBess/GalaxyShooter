{
  "name": "galaxy-shooter",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace @space-shmup/client",
    "dev:server": "npm run dev --workspace @space-shmup/server",
    "build": "npm run build --workspace @space-shmup/server && npm run build --workspace @space-shmup/client",
    "test": "npm run test --workspace @space-shmup/server"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}

